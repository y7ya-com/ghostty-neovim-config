theme = vscode-dark-modern
unfocused-split-opacity = 1.0
split-divider-color = #5a5a5a
window-decoration = true
macos-titlebar-style = native

# Override Ghostty's default bindings to pass these keys through to Neovim
# Uses kitty keyboard protocol codepoints: f=102, e=101, F(shift+f)=70
# Modifier: super=9, super+shift=10
keybind = super+f=text:\x1b[102;9u
keybind = super+b=text:\x1b[98;9u
keybind = super+shift+f=text:\x1b[70;10u
# super+p has no Ghostty default — Ghostty forwards it via kitty protocol automatically
